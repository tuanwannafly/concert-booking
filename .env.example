# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=concert_booking
MYSQL_USER=concert_user
MYSQL_PASSWORD=concert_pass

# Redis
REDIS_PASSWORD=redis_pass

# JWT (phải >= 256 bit / 32 ký tự)
JWT_SECRET=mySecretKeyForJWTShouldBeAtLeast256BitsLongForHS256Algorithm
JWT_EXPIRATION_MS=86400000

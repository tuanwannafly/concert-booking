                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/bookings/{{bookingId}}/status", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","bookings","{{bookingId}}","status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\",\n  \"reason\": \"Fraud detected — ops investigation\"\n}"
            }
          }
        },

        {
          "name": "Manual Status Update — Invalid Transition (expect 400)",
          "description": "Không thể chuyển sang WAITING_PAYMENT thủ công.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('BOOKING_INVALID_STATUS', () => {",
                  "    pm.expect(pm.response.json().errorCode).to.equal('BOOKING_INVALID_STATUS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/bookings/{{bookingId}}/status", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","bookings","{{bookingId}}","status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"WAITING_PAYMENT\",\n  \"reason\": null\n}"
            }
          }
        },

        {
          "name": "Ops Access Booking — Customer Token (expect 403)",
          "description": "Endpoint ops với customerToken phải nhận 403 ACCESS_DENIED.",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ops/bookings?page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","ops","bookings"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" }
              ]
            }
          }
        }

      ]
    },

    {
      "name": "🏷️ 6. Admin — Voucher Management",
      "description": "Requires Bearer {{adminToken}}. OPERATOR cannot access these endpoints.",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
      },
      "item": [

        {
          "name": "List All Vouchers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns voucher list', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('array');",
                  "    pm.expect(body.data.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/ops/vouchers", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","vouchers"] }
          }
        },

        {
          "name": "Create Voucher — PERCENT discount",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Voucher created', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.code).to.equal('SUMMER20');",
                  "    pm.expect(body.data.discountType).to.equal('PERCENT');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/vouchers", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","vouchers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER20\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 20,\n  \"maxUses\": 100,\n  \"minOrderAmount\": 500000,\n  \"validFrom\": \"2026-06-01T00:00:00\",\n  \"validTo\": \"2026-08-31T23:59:59\"\n}"
            }
          }
        },

        {
          "name": "Create Voucher — FIXED discount",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('discountType = FIXED', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.discountType).to.equal('FIXED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/vouchers", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","vouchers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"NEWUSER100K\",\n  \"discountType\": \"FIXED\",\n  \"discountValue\": 100000,\n  \"maxUses\": 50,\n  \"minOrderAmount\": null,\n  \"validFrom\": \"2026-01-01T00:00:00\",\n  \"validTo\": \"2026-12-31T23:59:59\"\n}"
            }
          }
        },

        {
          "name": "Create Voucher — Duplicate Code (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/vouchers", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","vouchers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"FLASHSALE10\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 5,\n  \"maxUses\": 10,\n  \"minOrderAmount\": null,\n  \"validFrom\": \"2026-01-01T00:00:00\",\n  \"validTo\": \"2026-12-31T23:59:59\"\n}"
            }
          }
        },

        {
          "name": "Create Voucher — Operator Token (expect 403)",
          "description": "Admin-only endpoint. Operator không được phép tạo voucher.",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 Forbidden', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/vouchers", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","vouchers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SHOULDFAIL\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 5,\n  \"maxUses\": 10,\n  \"minOrderAmount\": null,\n  \"validFrom\": \"2026-01-01T00:00:00\",\n  \"validTo\": \"2026-12-31T23:59:59\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "⚡ 7. Flash Sale — End-to-End Scenarios",
      "description": "Kịch bản kiểm tra toàn bộ luồng. Chạy theo thứ tự từ trên xuống.\n\nBước 1: Login (folder 0)\nBước 2: Chạy các request trong folder này theo thứ tự.",
      "item": [

        {
          "name": "E2E-01: Create Booking (Standard, 2 vé)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));",
                  "console.log('[E2E-01] New idempotencyKey:', pm.collectionVariables.get('idempotencyKey'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[E2E-01] 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('bookingId', String(body.data.id));",
                  "console.log('[E2E-01] bookingId =', body.data.id);",
                  "console.log('[E2E-01] totalAmount =', body.data.totalAmount);",
                  "pm.test('[E2E-01] totalAmount = 1,600,000', () => {",
                  "    pm.expect(body.data.totalAmount).to.equal(1600000);",
                  "});"
                ]
              }
            }
          ],
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
          },
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/bookings", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"ticketCategoryId\": 3,\n      \"quantity\": 2\n    }\n  ]\n}"
            }
          }
        },

        {
          "name": "E2E-02: Pay Step 1 (PENDING → WAITING_PAYMENT)",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[E2E-02] Status = WAITING_PAYMENT', () => {",
                  "    pm.expect(pm.response.json().data.status).to.equal('WAITING_PAYMENT');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/pay", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings","{{bookingId}}","pay"] }
          }
        },

        {
          "name": "E2E-03: Pay Step 2 (WAITING_PAYMENT → PAID)",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{customerToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[E2E-03] Status = PAID', () => {",
                  "    pm.expect(pm.response.json().data.status).to.equal('PAID');",
                  "});",
                  "pm.test('[E2E-03] paidAt set', () => {",
                  "    pm.expect(pm.response.json().data.paidAt).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/bookings/{{bookingId}}/pay", "host": ["{{baseUrl}}"], "path": ["api","v1","bookings","{{bookingId}}","pay"] }
          }
        },

        {
          "name": "E2E-04: Ops Mark COMPLETED (PAID → COMPLETED)",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[E2E-04] Status = COMPLETED', () => {",
                  "    pm.expect(pm.response.json().data.status).to.equal('COMPLETED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/ops/bookings/{{bookingId}}/status", "host": ["{{baseUrl}}"], "path": ["api","v1","ops","bookings","{{bookingId}}","status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\",\n  \"reason\": null\n}"
            }
          }
        },

        {
          "name": "E2E-05: Verify in Booking Stats",
          "auth": {
            "type": "bearer",
            "bearer": [{ "key": "token", "value": "{{operatorToken}}", "type": "string" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[E2E-05] completedCount >= 1', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data.completedCount).to.be.above(0);",
                  "    pm.expect(body.data.totalRevenue).to.be.above(0);",
                  "    console.log('[E2E-05] totalRevenue =', body.data.totalRevenue);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/ops/bookings/stats?concertId={{concertId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","ops","bookings","stats"],
              "query": [{ "key": "concertId", "value": "{{concertId}}" }]
            }
          }
        }

      ]
    }

  ]
}